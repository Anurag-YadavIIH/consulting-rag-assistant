# Copy to .env and fill in only what you need — the default setup uses no API
# keys at all and everything runs locally (offline demo, local Ollama).

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Hosted LLM / search APIs (optional — leave blank to stay fully local) ---
OPENAI_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# --- Postgres / pgvector (optional vector-store backend, see docker-compose.yml) ---
# Matches the credentials in docker-compose.yml's postgres service.
DATABASE_URL=postgresql://consultrag:consultrag@localhost:5432/consultrag

# --- OIDC authentication (Phase 4 API) ---
# Provider-agnostic: issuer and jwks_uri come from this discovery document at
# runtime, never hardcoded. Default targets Google; point at any other
# compliant OIDC provider's discovery URL to swap providers.
OAUTH_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# Your OAuth client ID — the token's `aud` claim must match this.
OAUTH_AUDIENCE=
