# Copy to .env.local for local dev.

# Base URL of the FastAPI backend. Browser-exposed (NEXT_PUBLIC_ prefix)
# because lib/api.ts calls it directly from the client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Comma-separated fallback engagement list, used only when /me returns zero
# engagements and is_admin is false (mirrors ui/app.py's FALLBACK_ENGAGEMENTS).
# Leave unset for the normal admin dev-bypass case — that's handled by
# is_admin, not this fallback.
NEXT_PUBLIC_FALLBACK_ENGAGEMENTS=
